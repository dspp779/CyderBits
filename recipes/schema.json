{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyder.local/schemas/game-recipe-v1.json",
  "title": "Cyder game recipe",
  "type": "object",
  "required": ["id", "revision", "displayName", "baseTemplate", "settings", "environment", "arguments", "components"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "revision": { "type": "integer", "minimum": 1 },
    "displayName": { "type": "string", "minLength": 1 },
    "baseTemplate": { "enum": ["pristine", "recommended"] },
    "settings": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dpi": { "type": "integer", "minimum": 1, "maximum": 768 },
        "retinaMode": { "type": "boolean" },
        "msync": { "type": "boolean" },
        "esync": { "type": "boolean" },
        "renderer": { "type": "string" }
      }
    },
    "environment": { "type": "object", "additionalProperties": { "type": "string" } },
    "arguments": { "type": "array", "items": { "type": "string" } },
    "components": { "type": "array", "items": { "type": "string" } }
  }
}
